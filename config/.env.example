# ============================================================
# EarningsEdge — Environment Variable Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- LLM API Keys ------------------------------------------
# Groq: https://console.groq.com  (free tier available)
GROQ_API_KEY=your_groq_api_key_here

# Google AI Studio: https://aistudio.google.com  (free tier)
GOOGLE_API_KEY=your_google_ai_studio_key_here

# ---- Model overrides (optional — defaults shown) -----------
# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-1.5-flash

# ---- SEC EDGAR ---------------------------------------------
# Required by EDGAR fair-access policy. Use your real info.
SEC_USER_AGENT=Your Name your@email.com

# ---- Chunking / Retrieval tweaks (optional) ----------------
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64
# TOP_K_RETRIEVAL=10

# ---- Backtesting window (optional) -------------------------
# BACKTEST_START_DATE=2019-01-01
# BACKTEST_END_DATE=2024-12-31
# INITIAL_CAPITAL=100000
